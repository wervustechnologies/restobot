# ============================================================
# VERCEL ENVIRONMENT VARIABLES
# Copy these keys into: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# Your Render backend URL (no trailing slash)
# Example: https://restobot-backend.onrender.com/api
VITE_API_BASE_URL=https://YOUR_RENDER_APP_NAME.onrender.com/api

# Public URL for QR codes (no trailing slash)
# In Vercel production this is auto-detected from window.location.origin
# For local dev, override if needed: http://192.168.1.x:5173
VITE_PUBLIC_URL=https://YOUR_VERCEL_APP.vercel.app
